# GitHub repo containing EPM branches (default: ESMAP-World-Bank-Group/EPM)
VITE_GITHUB_OWNER=ESMAP-World-Bank-Group
VITE_GITHUB_REPO=EPM

# Optional: personal access token to raise API rate limit from 60 to 5000 req/h
# Create at https://github.com/settings/tokens (no special scopes needed for public repos)
VITE_GITHUB_TOKEN=
